// Prisma schema for ApplyHub backend.
// The design keeps the MVP focused on application tracking:
// users own applications, and activity logs power the dashboard/grass view.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 지원 상태 값입니다.
// MVP에서는 지원 현황 추적에 꼭 필요한 상태만 사용합니다.
enum ApplicationStatus {
  // 관심은 있지만 아직 작성이나 제출을 시작하지 않은 공고입니다.
  INTERESTED

  // 자기소개서, 이력서, 포트폴리오 등을 작성 중인 공고입니다.
  WRITING

  // 실제 지원 제출을 완료한 공고입니다. 잔디 집계의 기준 상태입니다.
  APPLIED

  // 면접이 예정되었거나 면접 프로세스에 들어간 공고입니다.
  INTERVIEW

  // 최종 합격한 공고입니다.
  FINAL_PASSED

  // 서류, 면접, 최종 등 어느 단계에서든 불합격 처리된 공고입니다.
  REJECTED
}

// 활동 로그 종류입니다.
// MVP 잔디는 APPLIED 로그만 집계하지만, 추후 활동 타임라인 확장을 위해 타입을 분리합니다.
enum ActivityType {
  // 사용자가 새 지원 공고를 등록한 활동입니다.
  APPLICATION_CREATED

  // 지원 상태가 변경된 활동입니다.
  STATUS_CHANGED

  // 지원 상태가 APPLIED가 되면서 지원 완료로 기록된 활동입니다.
  APPLIED

  // 메모가 변경된 활동입니다.
  MEMO_UPDATED
}

model User {
  // 사용자 고유 식별자입니다.
  id           Int       @id @default(autoincrement())

  // 로그인 및 사용자 식별에 사용하는 이메일입니다.
  email        String    @unique

  // 화면에 표시할 사용자 이름입니다.
  name         String?

  // 비밀번호 인증을 사용할 경우 저장할 해시값입니다. OAuth만 사용할 경우 비어 있을 수 있습니다.
  passwordHash String?

  // 사용자가 등록한 지원 공고 목록입니다.
  applications Application[]

  // 사용자 기준으로 남겨진 활동 로그 목록입니다.
  activityLogs ActivityLog[]

  // 사용자 데이터가 처음 생성된 시각입니다.
  createdAt    DateTime  @default(now())

  // 사용자 데이터가 마지막으로 수정된 시각입니다.
  updatedAt    DateTime  @updatedAt

  @@map("users")
}

model Application {
  // 지원 공고 고유 식별자입니다.
  id          Int               @id @default(autoincrement())

  // 이 지원 공고를 소유한 사용자 ID입니다.
  userId      Int

  // 이 지원 공고를 소유한 사용자입니다.
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 회사명입니다. MVP에서는 별도 Company 테이블로 분리하지 않습니다.
  companyName String

  // 채용 공고 제목입니다.
  jobTitle    String

  // 지원 포지션 또는 직무명입니다.
  position    String?

  // 원본 채용 공고 URL입니다. URL이 있는 경우 같은 사용자의 중복 등록을 막습니다.
  jobUrl      String?

  // 잡코리아, 사람인, 원티드, 프로그래머스 등 채용 플랫폼 이름입니다.
  platform    String?

  // 현재 지원 상태입니다.
  status      ApplicationStatus @default(INTERESTED)

  // 공고 마감일입니다. 마감 임박 목록과 정렬에 사용합니다.
  deadline    DateTime?

  // 실제 지원 완료일입니다. 상태가 APPLIED가 될 때 저장합니다.
  appliedAt   DateTime?

  // 사용자가 자유롭게 적는 메모입니다.
  memo        String?

  // 해당 지원에 사용한 포트폴리오 버전입니다. MVP에서는 선택 입력으로 둡니다.
  portfolioVersion String?

  // 이 지원 공고에 연결된 활동 로그입니다.
  activityLogs ActivityLog[]

  // 지원 공고가 처음 등록된 시각입니다.
  createdAt   DateTime          @default(now())

  // 지원 공고가 마지막으로 수정된 시각입니다.
  updatedAt   DateTime          @updatedAt

  @@unique([userId, jobUrl])
  @@index([userId, status])
  @@index([userId, deadline])
  @@index([userId, appliedAt])
  @@map("applications")
}

model ActivityLog {
  // 활동 로그 고유 식별자입니다.
  id            Int          @id @default(autoincrement())

  // 이 활동을 수행한 사용자 ID입니다.
  userId        Int

  // 이 활동을 수행한 사용자입니다.
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 활동이 연결된 지원 공고 ID입니다.
  applicationId Int

  // 활동이 연결된 지원 공고입니다.
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // 활동 종류입니다. 잔디에서는 APPLIED만 집계합니다.
  activityType  ActivityType

  // 활동이 발생한 날짜입니다. 사용자의 로컬 날짜 기준으로 저장해 잔디 집계에 사용합니다.
  activityDate  DateTime

  // 상태 변경 전 값입니다. STATUS_CHANGED 로그에서 사용할 수 있습니다.
  fromStatus    ApplicationStatus?

  // 상태 변경 후 값입니다. STATUS_CHANGED/APPLIED 로그에서 사용할 수 있습니다.
  toStatus      ApplicationStatus?

  // 활동 로그가 생성된 시각입니다.
  createdAt     DateTime     @default(now())

  @@index([userId, activityType, activityDate])
  @@index([applicationId, activityType])
  @@map("activity_logs")
}
